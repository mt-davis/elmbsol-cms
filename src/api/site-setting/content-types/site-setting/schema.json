{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Setting",
    "description": "Global company, footer, and contact settings"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true
    },
    "siteUrl": {
      "type": "string",
      "required": true
    },
    "tagline": {
      "type": "text",
      "required": true
    },
    "contactEmail": {
      "type": "email",
      "required": true
    },
    "contactPhone": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "required": true
    },
    "contactCtaLabel": {
      "type": "string"
    },
    "contactCtaUrl": {
      "type": "string"
    },
    "privacyUrl": {
      "type": "string"
    },
    "termsUrl": {
      "type": "string"
    },
    "capabilityStatementUrl": {
      "type": "string"
    },
    "primaryNavigation": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link-item"
    },
    "footerNavigation": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link-item"
    },
    "legalNavigation": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link-item"
    },
    "footerCopyright": {
      "type": "string"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    }
  }
}
